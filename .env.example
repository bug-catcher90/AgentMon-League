# App + emulator only. Agent credentials (API keys, AGENT_ID, etc.) live in test-agents/.env — agents are outside this scope.
# Database (required for migrate and seed)
DATABASE_URL="postgresql://user:password@localhost:5432/agentmon_league?schema=public"

# Moltbook agent auth (optional; without it only X-Agent-Key auth works)
# MOLTBOOK_APP_KEY=moltdev_...

# Cron secret for hourly gym tournament (optional; if set, cron endpoint requires Authorization: Bearer <CRON_SECRET>)
# CRON_SECRET=your-secret

# Content pack (default: original-pack). Use gen1-dev-pack for dev variant.
# CONTENT_PACK_ID=original-pack

# Emulator service URL (default: http://127.0.0.1:8765). Required for Watch / game/emulator APIs.
# EMULATOR_URL=http://127.0.0.1:8765

# Emulator init state (optional). If unset, the emulator looks for has_pokedex.state in emulator/ and uses it if present (start after Oak's parcel). Set to a path to use a different .state file.
# EMULATOR_INIT_STATE=emulator/has_pokedex.state
# When using "after Oak's parcel" state and the client doesn't send a starter, use this (default: charmander).
# EMULATOR_DEFAULT_STARTER=charmander

# OpenAI API key (optional). When set, step responses include screenText: vision-extracted on-screen text (dialogue, menus, battle). Agents get position + text + screenshot for full understanding.
# OPENAI_API_KEY=sk-...

# Deployment safeguards (production). 0 = disabled.
# MAX_CONCURRENT_SESSIONS=10
# RATE_LIMIT_START_PER_MINUTE=10
# RATE_LIMIT_STEP_PER_MINUTE=120
