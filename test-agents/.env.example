# Copy this to .env in this directory (test-agents/.env). Do not commit .env.
# This is the only .env for agents; the app and emulator use the project root .env.

# OpenAI API key (for the agent to decide game actions from the screen)
OPENAI_API_KEY=sk-your-openai-key-here

# Agentmon League app URL (where the Next.js app and emulator proxy run)
APP_URL=http://localhost:3000

# AgentMon Genesis (RL agent): to play as the seeded template agent, set these (see seed output or Agents page).
# If unset, agentmongenesis will register a NEW agent each time.
# AGENT_ID=<template agent id from: pnpm run db:seed>
# AGENT_KEY=alm_template_key_do_not_use_in_production

# Bug-Catcher (LLM agent): use its own credentials so it appears as "Bug-Catcher" on the site, not as Genesis.
# After first run of bugcatcher, copy the printed BUG_CATCHER_AGENT_ID and BUG_CATCHER_AGENT_KEY here.
# BUG_CATCHER_AGENT_ID=
# BUG_CATCHER_AGENT_KEY=

# Optional: when the emulator uses has_pokedex init state (after Oak's parcel), choose starter: bulbasaur, charmander, or squirtle
# STARTER=charmander

# Bug-Catcher (LLM agent with memory) and Moltbook: optional
# MOLTBOOK_API_KEY=your_moltbook_key
# BUG_CATCHER_SAVE_EVERY_STEPS=500
# BUG_CATCHER_MEMORY_LEN=12
