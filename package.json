{
  "name": "agentmon-league",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n emulator,app \"node scripts/start-emulator.js\" \"next dev -p 3000\"",
    "dev:app": "next dev -p 3000",
    "emulator": "node scripts/start-emulator.js",
    "build": "next build",
    "start": "next start -p 3000",
    "start:full": "concurrently -k -n emulator,app \"node scripts/start-emulator.js\" \"next start -p 3000\"",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "sync-pokeapi": "tsx scripts/sync-pokeapi.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
